generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Auth ──────────────────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      String   @default("client") // "admin" | "client"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientProfile Client?
}

// ── Clients ──────────────────────────────────────────────────
model Client {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  name          String
  email         String?
  phone         String?
  location      String?
  leadSource    String?
  firstContact  DateTime?
  pipelineStage String   @default("enquiry") // enquiry, discovery, proposal, contract, booked
  status        String   @default("lead")    // lead, active, past, archived
  lifetimeValue Float    @default(0)
  notes         String?
  tags          String?  // stored as JSON array string

  // Legacy link to User for portal login
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  jobs         Job[]
  files        File[]
  activities   Activity[]
}

// ── Jobs ─────────────────────────────────────────────────────
model Job {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name          String
  jobType       String?  // wedding, anniversary, corporate, event, realestate, custom
  status        String   @default("enquiry") // enquiry, booked, preproduction, shootday, editing, review, approved, delivered, archived
  shootDate     DateTime?
  shootLocation String?
  quoteValue    Float?
  revisionLimit Int      @default(2)
  revisionsUsed Int      @default(0)
  notes         String?
  portalToken   String   @unique @default(cuid())

  tasks        JobTask[]
  deliverables Deliverable[]
  revisions    Revision[]
  proposals    Proposal[]
  events       Event[]
  activities   Activity[]
}

// ── Job Templates ────────────────────────────────────────────
model JobTemplate {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  jobType   String   @unique // wedding, anniversary, corporate, event, realestate, custom
  name      String

  templateTasks       TemplateTask[]
  templateDeliverables TemplateDeliverable[]
}

model TemplateTask {
  id         String      @id @default(cuid())
  templateId String
  template   JobTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  phase      String      // preshoot, shootday, postproduction, delivery
  title      String
  sortOrder  Int         @default(0)
}

model TemplateDeliverable {
  id          String      @id @default(cuid())
  templateId  String
  template    JobTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  title       String
  description String?
  sortOrder   Int         @default(0)
}

// ── Job Tasks ────────────────────────────────────────────────
model JobTask {
  id        String    @id @default(cuid())
  jobId     String
  job       Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  phase     String    // preshoot, shootday, postproduction, delivery
  title     String
  completed Boolean   @default(false)
  dueDate   DateTime?
  sortOrder Int       @default(0)
}

// ── Deliverables ─────────────────────────────────────────────
model Deliverable {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  title       String
  description String?
  completed   Boolean  @default(false)

  deliveryFiles DeliveryFile[]
}

// ── Delivery Files (portal) ──────────────────────────────────
model DeliveryFile {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  deliverableId String
  deliverable   Deliverable @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  fileName      String
  originalName  String
  fileUrl       String?  // external URL (Vimeo etc) or local path
  size          Int      @default(0)
  mimeType      String   @default("")
  versionLabel  String   @default("first_cut") // first_cut, revised_cut, final, raw
  personalNote  String?
  downloadEnabled Boolean @default(true)
  linkExpiry    DateTime?
  passwordHash  String?
  deliveryStatus String  @default("not_sent") // not_sent, sent, viewed, approved
  viewedAt      DateTime?
  approvedAt    DateTime?
}

// ── Proposals ────────────────────────────────────────────────
model Proposal {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  jobId        String
  job          Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  token        String    @unique @default(cuid())
  status       String    @default("draft") // draft, sent, accepted, declined
  coverNote    String?
  services     String    @default("[]") // JSON array of { description, amount }
  inclusions   String?
  paymentTerms String    @default("50% deposit to secure your date. Remaining 50% due 7 days before the shoot.")
  totalValue   Float     @default(0)
  sentAt       DateTime?
  respondedAt  DateTime?
}

// ── Revisions ────────────────────────────────────────────────
model Revision {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  round     Int
  request   String
  status    String   @default("pending") // pending, in_progress, completed
}

// ── Legacy Files (client uploads) ────────────────────────────
model File {
  id           String   @id @default(cuid())
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name         String
  originalName String
  size         Int
  mimeType     String
  description  String?
  uploadedAt   DateTime @default(now())
}

// ── Calendar Events ──────────────────────────────────────────
model Event {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  jobId     String?
  job       Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)
  title     String
  eventType String   // shoot, call, deadline, personal
  date      DateTime
  startTime String?  // stored as "HH:mm"
  endTime   String?  // stored as "HH:mm"
  notes     String?
}

// ── Gear & Equipment ─────────────────────────────────────────
model Gear {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  name          String
  category      String?  // camera, lens, audio, lighting, accessories, other
  purchaseValue Float?
  insuranceValue Float?
  serialNumber  String?
  status        String   @default("available") // available, out_on_shoot, in_service, retired
  notes         String?
}

// ── Documents & Templates ────────────────────────────────────
model Document {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name      String
  docType   String   // contract, callsheet, shotlist, questionnaire
  content   String   @default("")
}

// ── Notifications ────────────────────────────────────────────
model Notification {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  title     String
  message   String
  type      String   // portal_viewed, approved, revision_request, status_change, reminder
  read      Boolean  @default(false)
  linkUrl   String?
  jobId     String?
  clientId  String?
}

// ── Activity Log ─────────────────────────────────────────────
model Activity {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  action    String   // e.g. "status_changed", "delivery_sent", "revision_requested"
  details   String?
  jobId     String?
  job       Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
}
