# ── Database (Supabase PostgreSQL) ───────────────────────────
# Transaction mode connection (port 6543) — used by the app at runtime via Supabase connection pooler
DATABASE_URL="postgresql://postgres.evtxrdhdqixsxtuonkjn:[YOUR-PASSWORD]@aws-0-ap-southeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (port 5432) — used by Prisma for migrations and introspection
DIRECT_URL="postgresql://postgres.evtxrdhdqixsxtuonkjn:[YOUR-PASSWORD]@aws-0-ap-southeast-2.pooler.supabase.com:5432/postgres"

# ── Authentication ───────────────────────────────────────────
# Secret key for signing JWT session tokens (generate with: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-secure-random-string"
